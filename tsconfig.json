{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "preserve",
    "noEmit": true,
    "skipLibCheck": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "vueCompilerOptions": {
    "strictTemplates": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
